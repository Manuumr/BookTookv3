<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Fila Superior: Spinner + campana -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Spinner
                android:id="@+id/spAyudaRapida"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:spinnerMode="dropdown"
                android:prompt="@string/social_prompt_ayuda"
                android:entries="@array/social_ayudarapida_opciones"
                android:layout_marginEnd="8dp"/>

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/ivNotificaciones"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_notifications_black_24dp"
                    android:contentDescription="@string/social_notificaciones_desc" />

                <!-- Badge con número de notificaciones -->
                <TextView
                    android:id="@+id/tvBadgeNotificaciones"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="end"
                    android:gravity="center"
                    android:background="@drawable/bg_badge_notificacion"
                    android:text="3"
                    android:textColor="@android:color/white"
                    android:textSize="10sp" />
            </FrameLayout>

        </LinearLayout>

        <!-- Generar un espacio -->
        <View
            android:layout_width="match_parent"
            android:layout_height="16dp" />

        <!-- TÍTULO Y SUBTÍTULO -->
        <TextView
            android:id="@+id/tvSaludoSocial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="26sp"
            android:textStyle="bold" />


        <TextView
            android:id="@+id/tvSubtituloSocial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text=""
            android:textSize="14sp" />

        <!-- GRID DE CARDS (2 x 2) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Fila 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Card: Añadir amigos -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAnadirAmigos"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvTituloCardAnadir"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/social_card_anadir_amigos_titulo"
                            android:textStyle="bold"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvDescCardAnadir"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/social_card_anadir_amigos_desc"
                            android:textSize="12sp" />
                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Card: Ajustes de privacidad -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardPrivacidad"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvTituloCardPrivacidad"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/social_card_privacidad_titulo"
                            android:textStyle="bold"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvDescCardPrivacidad"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/social_card_privacidad_desc"
                            android:textSize="12sp" />
                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Fila 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Card: Gestionar amigos -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardGestionAmigos"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvTituloCardGestion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/social_card_gestion_titulo"
                            android:textStyle="bold"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvDescCardGestion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/social_card_gestion_desc"
                            android:textSize="12sp" />
                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Card: Otros ajustes -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardOtrosAjustes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvTituloCardOtros"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/social_card_otros_titulo"
                            android:textStyle="bold"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvDescCardOtros"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/social_card_otros_desc"
                            android:textSize="12sp" />
                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>

        <!-- ESPACIO -->
        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />

        <!-- SWITCH IDIOMA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/social_idioma_label"
                android:textSize="14sp" />

            <Switch
                android:id="@+id/switchIdioma"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textOn="@string/social_switch_en"
                android:textOff="@string/social_switch_es"
                android:checked="false" />


        </LinearLayout>

    </LinearLayout>

</ScrollView>