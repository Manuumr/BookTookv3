<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/book_grid_item_margin"
    android:clipChildren="false"
    android:clipToPadding="false"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardUseCompatPadding="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingBottom="6dp">

        <ImageView
            android:id="@+id/ivPortada"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:contentDescription="@string/desc_portada_libro"
            android:scaleType="fitCenter"
            app:layout_constraintDimensionRatio="2:3"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@drawable/ic_launcher_foreground" />

        <ImageButton
            android:id="@+id/btnFavorito"
            android:layout_width="@dimen/book_fav_size"
            android:layout_height="@dimen/book_fav_size"
            android:layout_margin="@dimen/book_fav_margin"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/desc_favorito"
            android:elevation="6dp"
            android:padding="2dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_star_border"
            app:layout_constraintEnd_toEndOf="@id/ivPortada"
            app:layout_constraintTop_toTopOf="@id/ivPortada"
            app:tint="@color/yellowFavs" />

        <TextView
            android:id="@+id/tvTituloLibro"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivPortada"
            tools:text="Título del libro" />

        <TextView
            android:id="@+id/tvAutorLibro"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textSize="11sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTituloLibro"
            tools:text="Autor" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
